{
    "buildCommand": "npm run build:vercel",
    "outputDirectory": "dist/client",
    "framework": null,
    "functions": {
        "api/index.js": {
            "maxDuration": 30
        }
    },
    "rewrites": [
        { "source": "/api/(.*)", "destination": "/api" },
        { "source": "/t/(.*)", "destination": "/api" },
        { "source": "/health", "destination": "/api" },
        { "source": "/(.*)", "destination": "/index.html" }
    ]
}
