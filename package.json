{
    "name": "skaleclub-mail",
    "version": "1.0.0",
    "description": "Complete email system with React, Express, and Supabase",
    "type": "module",
    "scripts": {
        "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
        "dev:client": "vite",
        "dev:server": "tsx watch src/server/index.ts",
        "build": "npm run build:client && npm run build:server",
        "build:client": "vite build",
        "build:server": "tsc -p tsconfig.server.json",
        "build:api": "esbuild src/server/index.ts --bundle --platform=node --format=esm --packages=external --outfile=api/index.js",
        "build:vercel": "npm run build:client && npm run build:api",
        "preview": "vite preview",
        "start": "node dist/server/index.js",
        "db:generate": "drizzle-kit generate:pg",
        "db:push": "drizzle-kit push:pg",
        "db:studio": "drizzle-kit studio",
        "db:rls": "tsx scripts/run-rls-migration.ts",
        "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
    },
    "dependencies": {
        "@hookform/resolvers": "^3.3.4",
        "@radix-ui/react-accordion": "^1.1.2",
        "@radix-ui/react-alert-dialog": "^1.0.5",
        "@radix-ui/react-avatar": "^1.0.4",
        "@radix-ui/react-checkbox": "^1.0.4",
        "@radix-ui/react-dialog": "^1.0.5",
        "@radix-ui/react-dropdown-menu": "^2.0.6",
        "@radix-ui/react-icons": "^1.3.0",
        "@radix-ui/react-label": "^2.0.2",
        "@radix-ui/react-popover": "^1.0.7",
        "@radix-ui/react-progress": "^1.0.3",
        "@radix-ui/react-scroll-area": "^1.0.5",
        "@radix-ui/react-select": "^2.0.0",
        "@radix-ui/react-separator": "^1.0.3",
        "@radix-ui/react-slot": "^1.0.2",
        "@radix-ui/react-switch": "^1.0.3",
        "@radix-ui/react-tabs": "^1.0.4",
        "@radix-ui/react-toast": "^1.1.5",
        "@radix-ui/react-tooltip": "^1.0.7",
        "@supabase/supabase-js": "^2.39.8",
        "@tanstack/react-query": "^5.28.0",
        "@tanstack/react-table": "^8.13.2",
        "@types/bcrypt": "^6.0.0",
        "@types/imap": "^0.8.43",
        "@types/smtp-server": "^3.5.12",
        "bcrypt": "^6.0.0",
        "class-variance-authority": "^0.7.0",
        "clsx": "^2.1.0",
        "cmdk": "^1.0.0",
        "cors": "^2.8.5",
        "date-fns": "^3.6.0",
        "date-fns-tz": "^3.1.3",
        "dotenv": "^16.4.5",
        "drizzle-orm": "^0.30.4",
        "drizzle-zod": "^0.5.1",
        "express": "^5.0.0-beta.2",
        "express-rate-limit": "^7.2.0",
        "helmet": "^7.1.0",
        "imap": "^0.8.19",
        "imapflow": "^1.2.16",
        "jsonwebtoken": "^9.0.2",
        "lodash": "^4.17.21",
        "lucide-react": "^0.358.0",
        "mailparser": "^3.6.9",
        "node-cron": "^4.2.1",
        "nodemailer": "^6.9.12",
        "postgres": "^3.4.3",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-hook-form": "^7.51.0",
        "react-markdown": "^9.0.1",
        "recharts": "^2.12.3",
        "smtp-server": "^3.18.2",
        "tailwind-merge": "^2.2.2",
        "tailwindcss-animate": "^1.0.7",
        "uuid": "^9.0.1",
        "wouter": "^3.0.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/lodash": "^4.17.0",
        "@types/mailparser": "^3.4.6",
        "@types/node": "^20.11.28",
        "@types/node-cron": "^3.0.11",
        "@types/nodemailer": "^6.4.14",
        "@types/react": "^18.2.66",
        "@types/react-dom": "^18.2.22",
        "@types/uuid": "^9.0.8",
        "@typescript-eslint/eslint-plugin": "^7.2.0",
        "@typescript-eslint/parser": "^7.2.0",
        "@vitejs/plugin-react": "^4.2.1",
        "autoprefixer": "^10.4.18",
        "concurrently": "^8.2.2",
        "drizzle-kit": "^0.20.17",
        "eslint": "^8.57.0",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-react-refresh": "^0.4.5",
        "postcss": "^8.4.35",
        "tailwindcss": "^3.4.1",
        "tsx": "^4.7.1",
        "typescript": "^5.4.2",
        "vite": "^5.1.6"
    }
}
