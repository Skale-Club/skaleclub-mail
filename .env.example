# Supabase Configuration (server-side)
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase Configuration (client-side - Vite requires VITE_ prefix)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Database - Supabase Pooler Connection (for Drizzle ORM)
# Use the pooler connection string from Supabase Dashboard > Settings > Database > Connection string > Mode: Session
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Server Configuration
PORT=9001
NODE_ENV=development

# JWT Secret for additional security
JWT_SECRET=your_jwt_secret_key

# Email Configuration (for sending emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@example.com

# Frontend URL
FRONTEND_URL=http://localhost:9000

# ─── Native Mail Server ────────────────────────────────────────────────────────
# The hostname Thunderbird / mail clients connect to
MAIL_HOST=localhost
MAIL_DOMAIN=mail.yourdomain.com

# SMTP Submission port (587 in production, 2587 in dev to avoid needing root)
SMTP_SUBMISSION_PORT=2587

# IMAP port (993 in production, 2993 in dev to avoid needing root)
IMAP_PORT=2993

# TLS (leave blank for dev; set in prod for real SSL)
# MAIL_TLS_CERT_PATH=/etc/letsencrypt/live/mail.yourdomain.com/fullchain.pem
# MAIL_TLS_KEY_PATH=/etc/letsencrypt/live/mail.yourdomain.com/privkey.pem
