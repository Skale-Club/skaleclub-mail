# Supabase Configuration (server-side)
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase Configuration (client-side - Vite requires VITE_ prefix)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Database - Supabase Pooler Connection (for Drizzle ORM)
# Use the pooler connection string from Supabase Dashboard > Settings > Database > Connection string > Mode: Session
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Server Configuration
PORT=9001
NODE_ENV=development

# First user auto-admin (set to true to make the first authenticated user an admin)
AUTO_ADMIN_FIRST_USER=true

# DNS resolvers for domain verification (comma-separated, default: 8.8.8.8,1.1.1.1)
# DNS_SERVERS=8.8.8.8,1.1.1.1

# Base URL for tracking links (default: http://localhost:PORT)
# BASE_URL=https://mail.example.com

# JWT Secret for additional security
JWT_SECRET=your_jwt_secret_key

# Email Configuration (for sending emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@example.com

# Frontend URL
FRONTEND_URL=http://localhost:9000

# Microsoft Outlook / Microsoft 365 OAuth
MICROSOFT_CLIENT_ID=your_microsoft_app_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_app_client_secret
MICROSOFT_REDIRECT_URI=http://localhost:9001/api/outlook/callback
OUTLOOK_TOKEN_ENCRYPTION_KEY=use_a_long_random_secret_here
