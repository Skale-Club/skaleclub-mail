# Supabase Configuration (server-side)
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase Configuration (client-side - Vite requires VITE_ prefix)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Application branding (initial page title before React loads; DB branding overrides at runtime)
VITE_APP_NAME=Skale Club Mail

# Server-side branding fallback (used if DB has no branding record)
APP_COMPANY_NAME=Skale Club
APP_APPLICATION_NAME=Skale Club Mail

# Database - Supabase Pooler Connection (for Drizzle ORM)
# Use the pooler connection string from Supabase Dashboard > Settings > Database > Connection string > Mode: Session
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Server Configuration
PORT=9001
NODE_ENV=development

# JWT Secret for SMTP/IMAP auth and token signing
JWT_SECRET=your_jwt_secret_key

# Encryption keys (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your_encryption_key
OUTLOOK_TOKEN_ENCRYPTION_KEY=your_outlook_encryption_key

# Email Configuration (for sending emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@example.com

# Frontend URL
FRONTEND_URL=http://localhost:9000

# ─── Native Mail Server ────────────────────────────────────────────────────────
# The hostname Thunderbird / mail clients connect to
MAIL_HOST=localhost
MAIL_DOMAIN=mail.yourdomain.com

# SMTP Submission port (587 prod = STARTTLS, 465 prod = implicit TLS, 2587 dev)
SMTP_SUBMISSION_PORT=2587

# IMAP port (993 prod = implicit TLS, 2993 dev)
IMAP_PORT=2993

# TLS certificates — required for production use
# When set: IMAP uses implicit TLS, SMTP/MX offer STARTTLS (implicit TLS on 465)
# When unset: servers run in plaintext (dev mode). Mail clients will refuse or warn.
# On Hetzner: install certbot on host, mount /etc/letsencrypt into container via
# docker run -v /etc/letsencrypt:/etc/letsencrypt:ro (deploy workflow does this).
# MAIL_TLS_CERT_PATH=/etc/letsencrypt/live/mail.skale.club/fullchain.pem
# MAIL_TLS_KEY_PATH=/etc/letsencrypt/live/mail.skale.club/privkey.pem

# Toggle to force-enable the embedded SMTP/IMAP servers on platforms that
# otherwise disable them (e.g. Railway). Default: enabled unless RAILWAY_ENVIRONMENT set.
# ENABLE_MAIL_SERVER=true

# Inbound MX receiver — accepts email from the public internet for local
# mailboxes and routed addresses. Disabled by default (port 25 requires
# root/CAP_NET_BIND_SERVICE and MX DNS pointing to this server).
# ENABLE_MX_RECEIVER=true
# MX_PORT=25  # defaults to 25 in prod, 2525 in dev
